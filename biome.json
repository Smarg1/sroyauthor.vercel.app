{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",

  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },

  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!node_modules",
      "!.next",
      "!dist",
      "!build",
      "!coverage",
      "!src/lib/types/db.types.ts"
    ]
  },

  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },

  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },

  "linter": {
    "enabled": true,

    "rules": {
      "recommended": true,

      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error",
        "noConstAssign": "error"
      },

      "suspicious": {
        "noDebugger": "error",
        "noConsole": {
          "level": "warn",
          "options": {
            "allow": ["warn", "error"]
          }
        },
        "noDuplicateCase": "error",
        "noFallthroughSwitchClause": "error",
        "noImplicitAnyLet": "error",
        "noCompareNegZero": "error",
        "noUnknownAtRules": "off"
      },

      "style": {
        "useConst": "error",
        "useTemplate": "error",
        "useBlockStatements": "error",
        "useShorthandAssign": "error",
        "useShorthandFunctionType": "error",
        "useSingleVarDeclarator": "off"
      },

      "complexity": {
        "noUselessFragments": "error",
        "noExtraBooleanCast": "error",
        "useOptionalChain": "error",
        "useSimplifiedLogicExpression": "error"
      },

      "performance": {
        "noDelete": "warn"
      }
    },

    "domains": {
      "react": "recommended",
      "next": "recommended"
    }
  },

  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },

  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
