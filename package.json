    "next-seo": "^7.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remark-gfm": "^4.0.1",
    "simple-icons": "^16.13.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
